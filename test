server {
    listen 80;
    server_name hugscakesnevents.com.com www.hugscakesnevents.com.com;

    location / {
        proxy_pass http://unix:/run/hugs_and_cakes.sock;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /static/ {
        alias /var/www/hugs_and_cakes/staticfiles/;
    }

    location /media/ {
        alias /var/www/hugs_and_cakes/media/;
    }
}