[Unit]
Description=gunicorn daemon
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/var/www/hugs_and_cakes
ExecStart=/var/www/hugs_and_cakes/.venv/bin/gunicorn \
          --workers 3 \
          --bind unix:/var/www/hugs_and_cakes/gunicorn.sock \
          core.wsgi:application

[Install]
WantedBy=multi-user.target